// ═══════════════════════════════════════════════════════════════════════════════
// Registry Schema — Central database for store registration & auth lookup
// Only used for: finding store by code, user login lookup
// ═══════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Store Registry ─────────────────────────────────────────────────────────

model Store {
  id        String   @id @default(cuid())
  code      String   @unique       // store code used at login: "KENGI-HCM"
  name      String
  address   String?
  phone     String?
  logo      String?
  status    String   @default("active") // active | inactive | suspended
  schema    String   @unique       // PostgreSQL schema name: "store_kengi_hcm"
  plan      String   @default("full")    // retail | wholesale | full
  addOns    String   @default("[]")      // JSON array of add-on IDs e.g. ["online","extra_branch"]
  extraBranches Int  @default(0)         // number of extra branches
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
