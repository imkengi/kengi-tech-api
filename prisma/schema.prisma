// ═══════════════════════════════════════════════════════════════════════════════
// Registry Schema — Central database for store registration & auth lookup
// Only used for: finding store by code, user login lookup, refresh tokens
// ═══════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Store Registry ─────────────────────────────────────────────────────────

model Store {
  id        String   @id @default(cuid())
  code      String   @unique       // store code used at login: "KENGI-HCM"
  name      String
  address   String?
  phone     String?
  logo      String?
  status    String   @default("active") // active | inactive | suspended
  schema    String   @unique       // PostgreSQL schema name: "store_kengi_hcm"
  plan      String   @default("full")    // retail | wholesale | full
  addOns    String   @default("[]")      // JSON array of add-on IDs e.g. ["online","extra_branch"]
  extraBranches Int  @default(0)         // number of extra branches
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Refresh Token Store (persistent, survives server restarts) ──────────────
// Stores refresh tokens in PostgreSQL instead of in-memory Map.
// This ensures tokens remain valid across Cloud Run restarts/cold-starts.

model RefreshToken {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String
  email        String
  role         String
  storeId      String
  storeCode    String
  branchId     String?
  branchSchema String
  isMainBranch Boolean  @default(false)
  deviceId     String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ─── Pending 2FA Store (persistent, survives server restarts) ─────────────────
// Holds the partially-authenticated login state between /login (password OK,
// 2FA required) and /verify-2fa. Stored in PostgreSQL instead of an in-memory
// Map so that on Cloud Run the verify request can land on any instance.
// Rows are short-lived (5 min TTL) and deleted on successful verification.

model Pending2FA {
  id           String   @id @default(cuid())
  loginToken   String   @unique
  userId       String
  email        String
  role         String
  storeId      String
  storeCode    String
  branchId     String?
  branchSchema String
  isMainBranch Boolean  @default(false)
  deviceId     String?
  userData     String   // JSON-encoded user payload returned after verification
  storeData    String   // JSON-encoded store payload returned after verification
  branchData   String?  // JSON-encoded branch payload (nullable)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([loginToken])
  @@index([expiresAt])
}
