{
  "name": "open-retail-api",
  "version": "1.0.0",
  "description": "Backend API for Open-Retail POS System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "build": "npx prisma db push && npx tsx prisma/seed.ts && npx esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --packages=external --format=cjs",
    "build:tsc": "tsc",
    "start": "node dist/index.js",
    "postinstall": "npx prisma generate",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:migrate": "npx prisma db push",
    "db:reset": "npx prisma db push --force-reset && npx tsx prisma/seed.ts",
    "docker:build": "docker build -t open-retail-api .",
    "docker:run": "docker run -p 8080:8080 --env-file .env.gcloud open-retail-api",
    "deploy:gcloud": "gcloud builds submit --config cloudbuild.yaml ."
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.10.2",
    "prisma": "^6.4.1",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}